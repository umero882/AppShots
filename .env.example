# Copy to .env.local and fill in to enable the real backend.
# Without these, the app runs on a built-in localStorage backend (no setup needed).

# --- Supabase (recommended backend) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Stripe Checkout (client-only) ---
VITE_STRIPE_PUBLISHABLE_KEY=
VITE_STRIPE_PRICE_PRO=

# =====================================================================
# SERVER-ONLY keys (NO VITE_ prefix). These are read by the /api proxy
# in Node and are NEVER bundled into the browser. The client calls
# same-origin /api/* endpoints; only the proxy holds these secrets.
# =====================================================================

# --- Pexels image search (optional) ---
# Free key from https://www.pexels.com/api/ . Without it, search falls back to
# Openverse (Creative Commons, no key).
PEXELS_API_KEY=

# --- AI background generator ---
# Anthropic key powers the "AI" background tab (GitHub repo + prompt -> 2 on-brand
# gradients). Server-side via the proxy, so it does not ship to the browser.
ANTHROPIC_API_KEY=
# Optional — enables the "Generate image" button (real text-to-image). Set ONE.
OPENAI_API_KEY=
STABILITY_API_KEY=
# Optional GitHub token — lets the AI tab read your PRIVATE repos (the API returns
# 404 for private repos when unauthenticated). Fine-grained, read-only "Contents"
# + "Metadata" on the repos you'll use is enough.
GITHUB_TOKEN=
