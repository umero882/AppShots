# Copy to .env.local and fill in to override defaults.

# --- Firebase (ACTIVE backend) ---
# AppShots ships with the `appshots-76a56` Firebase web config baked into
# src/lib/firebase.js (a public client identifier, not a secret), so Firebase is
# the active backend with no env setup. Set these ONLY to point at a different
# project, or set VITE_FIREBASE_DISABLED=1 to fall back to localStorage.
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
# VITE_FIREBASE_MEASUREMENT_ID=
# VITE_FIREBASE_DISABLED=

# --- Supabase (legacy fallback; used only if Firebase is disabled) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# =====================================================================
# SERVER-ONLY keys (NO VITE_ prefix). These are read by the /api proxy
# in Node and are NEVER bundled into the browser. The client calls
# same-origin /api/* endpoints; only the proxy holds these secrets.
# =====================================================================

# --- Pexels image search (optional) ---
# Free key from https://www.pexels.com/api/ . Without it, search falls back to
# Openverse (Creative Commons, no key).
PEXELS_API_KEY=

# --- AI background generator ---
# Anthropic key powers the "AI" background tab (GitHub repo + prompt -> 2 on-brand
# gradients). Server-side via the proxy, so it does not ship to the browser.
ANTHROPIC_API_KEY=
# Optional — enables the "Generate image" button (real text-to-image). Set ONE.
OPENAI_API_KEY=
STABILITY_API_KEY=
# Optional GitHub token — lets the AI tab read your PRIVATE repos (the API returns
# 404 for private repos when unauthenticated). Fine-grained, read-only "Contents"
# + "Metadata" on the repos you'll use is enough.
GITHUB_TOKEN=

# --- Stripe subscription billing (server-side; hosted Checkout) ---
# The client never sees these — the server creates Checkout/portal sessions and
# returns only a redirect URL. See STRIPE-SETUP.md for the full walkthrough.
# Test secret key: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
# Webhook signing secret for /api/stripe/webhook.
#   Local:      stripe listen --forward-to localhost:5173/api/stripe/webhook
#   Production: Dashboard → Developers → Webhooks → your endpoint → signing secret
STRIPE_WEBHOOK_SECRET=whsec_...
# Stripe Tax is auto-on; set "false" to disable. (Checkout still works if Tax setup
# is incomplete — it retries once without tax.)
STRIPE_AUTOMATIC_TAX=true
# Absolute app URL for Checkout success/cancel + portal return links. Optional
# locally (falls back to the request Origin); REQUIRED in production.
APP_URL=https://appshots.nextechlabs.tech
