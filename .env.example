# Copy to .env.local and fill in to enable the real backend.
# Without these, the app runs on a built-in localStorage backend (no setup needed).

# --- Supabase (recommended backend) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Stripe Checkout (client-only) ---
VITE_STRIPE_PUBLISHABLE_KEY=
VITE_STRIPE_PRICE_PRO=

# --- Pexels image search (optional, "studio-grade" backgrounds) ---
# Free key from https://www.pexels.com/api/ . Without it, background search
# falls back to Openverse (Creative Commons). NOTE: this is a client-side app,
# so this key ships in the browser bundle — use a free, rate-limited key only.
VITE_PEXELS_API_KEY=
