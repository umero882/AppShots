# Copy to .env.local and fill in to enable the real backend.
# Without these, the app runs on a built-in localStorage backend (no setup needed).

# --- Supabase (recommended backend) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Stripe Checkout (client-only) ---
VITE_STRIPE_PUBLISHABLE_KEY=
VITE_STRIPE_PRICE_PRO=

# --- Pexels image search (optional, "studio-grade" backgrounds) ---
# Free key from https://www.pexels.com/api/ . Without it, background search
# falls back to Openverse (Creative Commons). NOTE: this is a client-side app,
# so this key ships in the browser bundle — use a free, rate-limited key only.
VITE_PEXELS_API_KEY=

# --- AI background generator ---
# Anthropic key powers the "AI" background tab (analyzes a GitHub repo + prompt,
# suggests 2 on-brand gradients). SECURITY: VITE_* keys are bundled into the
# client and visible on any deployed build. Fine for local dev; before deploying,
# proxy this behind a server or use a strictly spend-capped key.
VITE_ANTHROPIC_API_KEY=
# Optional — enables the "Generate image" button (real text-to-image). Same
# client-bundle caveat applies. Set ONE of these.
VITE_OPENAI_API_KEY=
VITE_STABILITY_API_KEY=
# Optional GitHub token — lets the AI tab read your PRIVATE repos (the public API
# returns 404 for private repos when unauthenticated). A fine-grained token with
# read-only "Contents" + "Metadata" on the repos you'll use is enough. Same
# client-bundle caveat — keep it minimally scoped.
VITE_GITHUB_TOKEN=
